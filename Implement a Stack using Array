class StackArray {
    int top = -1;
    int[] arr = new int[5];

    void push(int x) {
        if (top == arr.length - 1) System.out.println("Overflow");
        else arr[++top] = x;
    }

    int pop() {
        if (top == -1) { System.out.println("Underflow"); return -1; }
        return arr[top--];
    }

    int peek() { return (top == -1) ? -1 : arr[top]; }
}

int n = 5;
int[][] pascal = new int[n][n];

for(int i=0; i<n; i++){
    pascal[i][0] = 1;   // [first element of each row]
    for(int j=1; j<=i; j++){
        pascal[i][j] = pascal[i-1][j-1] + pascal[i-1][j];  // [sum of two above]
    }
}

// [print triangle]
for(int i=0; i<n; i++){
    for(int j=0; j<=i; j++){
        System.out.print(pascal[i][j] + " ");
    }
    System.out.println();
}
